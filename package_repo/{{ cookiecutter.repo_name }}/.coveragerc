[run]
branch = True
source = src/{{ cookiecutter.package_name }}
data_file = ~/localfiles/.coverage_{{ cookiecutter.package_name }}

[report]
exclude_lines =
    if self.debug:
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:

ignore_errors = True
omit =
    tests/*
    setup.py
    # this file is autogenerated by dbx
    src/{{ cookiecutter.package_name }}/common.py
