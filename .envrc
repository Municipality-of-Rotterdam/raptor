# direnv configuration — auto-sets UV_PROJECT_ENVIRONMENT per project.
# This ensures uv sync/run uses a local disk path instead of the
# (potentially network-mounted) project directory.
# Works for both conda + uv and uv-only workflows.

CONDA_ENV_PATH="/anaconda/envs/raptor"
LOCAL_ENV_PATH="${HOME}/.local/share/uv/envs/raptor"

if [ -d "$CONDA_ENV_PATH" ]; then
    # Conda environment exists — use it so conda and uv packages coexist
    export UV_PROJECT_ENVIRONMENT="$CONDA_ENV_PATH"
else
    # No conda env — use a local disk path for uv-only workflow
    mkdir -p "$LOCAL_ENV_PATH"
    export UV_PROJECT_ENVIRONMENT="$LOCAL_ENV_PATH"
fi
